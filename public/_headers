# Cloudflare Pages headers. Long-cache hashed assets, sensible security headers,
# and a CSP that still allows the (optional) Cloudflare Web Analytics / GoatCounter
# beacons plus Cloudflare Turnstile (script + iframe from challenges.cloudflare.com,
# used to bot-protect the chat). The chat itself calls same-origin /api/ask.
# tile.openstreetmap.org (img-src) serves the Home watch-party map tiles;
# nominatim.openstreetmap.org (connect-src) geocodes the "find closest" address
# fallback; geolocation=(self) lets that control ask for the browser location.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(self), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self' data: https://tile.openstreetmap.org https://*.tile.openstreetmap.org; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' https://static.cloudflareinsights.com https://gc.zgo.at https://challenges.cloudflare.com; frame-src 'self' https://challenges.cloudflare.com; connect-src 'self' https://cloudflareinsights.com https://*.goatcounter.com https://nominatim.openstreetmap.org; object-src 'none'

# Content-hashed build assets are immutable — cache them hard.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/og/*
  Cache-Control: public, max-age=86400
