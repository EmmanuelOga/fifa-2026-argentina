# direnv config — auto-loads the toolchain + local secrets when you cd in.
# First time: run `direnv allow` (needs `brew install direnv` + its shell hook).
# Safe to commit: contains NO secrets, only references to gitignored dotfiles.

# Toolchain: put the mise-pinned Node 26 / pnpm 10 (see mise.toml) on PATH.
if command -v mise >/dev/null 2>&1; then
  eval "$(mise env)"
fi

# Local-only secrets for the Ask-the-research chat / `wrangler pages dev`.
# Copy .env.example → .env (SDK/tools), or use .dev.vars (wrangler). Both gitignored.
dotenv_if_exists .env
dotenv_if_exists .dev.vars
