---
/**
 * Tab 3 island — Bayesian Explorer. Pick a hypothesis, set a prior and evidence
 * strengths (likelihood ratios); the posterior updates in log-odds and is drawn
 * against the author's published range band. Reset reproduces the published band.
 */
import type { Locale } from '../../lib/i18n';
import { HTML_LANG } from '../../lib/i18n';
import { UI } from '../../i18n/ui';
import { section, hypotheses } from '../../lib/content';
import { BAYES } from '../../data/bayes';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const s = UI[locale].sim;
const how = await section('prob-bayes-how', locale);
const assumption = await section('prob-bayes-intro', locale);
const hypos = await hypotheses();

// merge published bands (from content) with evidence config (from data)
const models = BAYES.map((b) => {
  const h = hypos.find((x) => x.data.code === b.code)!;
  return {
    code: b.code,
    label: h.data.content[locale].headline,
    low: h.data.rangeLow,
    high: h.data.rangeHigh,
    evidence: b.evidence.map((e) => ({
      id: e.id,
      label: e.label[locale],
      lrMin: e.lrMin,
      lrMax: e.lrMax,
      defaultLR: e.defaultLR,
    })),
  };
});

const config = { numLocale: HTML_LANG[locale], labels: s, models };
---

<div class="sim card" data-sim="bayes">
  <script type="application/json" is:inline data-config set:html={JSON.stringify(config)} />
  <p class="sim-flag spec">{UI[locale].speculative}</p>

  <div class="hypo-picker" role="tablist" data-picker>
    {
      models.map((m, i) => (
        <button
          type="button"
          role="tab"
          class:list={['hbtn', { active: i === 0 }]}
          data-hypo={m.code}
          aria-selected={i === 0 ? 'true' : 'false'}
        >
          <b>{m.code}</b> <span>{m.label}</span>
        </button>
      ))
    }
  </div>

  <div class="sim-grid">
    <div class="controls">
      <label class="ctrl">
        <span class="ctrl-label">{s.prior}: <b class="data" data-out="prior">—</b></span>
        <input type="range" min="1" max="99" step="1" value="50" data-in="prior" />
      </label>
      <div class="evidence" data-evidence></div>
      <button type="button" class="btn reset" data-reset>↺ {s.reset}</button>
    </div>

    <div class="readout">
      <p class="big-label">{s.posterior}</p>
      <p class="big-num data" data-out="posterior">—</p>
      <div class="band" data-band>
        <div class="band-range" data-band-range></div>
        <div class="band-marker" data-band-marker></div>
        <span class="band-label lo data" data-band-lo></span>
        <span class="band-label hi data" data-band-hi></span>
      </div>
      <p class="band-caption">{s.publishedRange}</p>
    </div>
  </div>

  <details class="math">
    <summary>{UI[locale].theMath} — Bayes</summary>
    <p>{how.full}</p>
    <p class="assump">{assumption.full}</p>
  </details>
</div>

<style>
  .sim {
    padding: var(--s-5);
  }
  .sim-flag {
    margin: 0 0 var(--s-4);
  }
  .hypo-picker {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    margin-bottom: var(--s-5);
  }
  .hbtn {
    font: inherit;
    text-align: left;
    cursor: pointer;
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: var(--radius-sm);
    padding: 0.45em 0.7em;
    font-size: 0.82rem;
    color: var(--muted);
    max-width: 15rem;
  }
  .hbtn b {
    font-family: var(--font-data);
    color: var(--sky-ink);
  }
  .hbtn.active {
    border-color: var(--sky);
    background: var(--sky-soft);
    color: var(--ink);
  }
  .sim-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--s-5);
  }
  @media (max-width: 720px) {
    .sim-grid {
      grid-template-columns: 1fr;
    }
  }
  .controls {
    display: grid;
    gap: var(--s-4);
    align-content: start;
  }
  .ctrl {
    display: grid;
    gap: var(--s-2);
  }
  .ctrl-label {
    font-size: 0.88rem;
    font-weight: 500;
  }
  .ctrl-label b {
    color: var(--sky-ink);
  }
  input[type='range'] {
    width: 100%;
    accent-color: var(--sky);
  }
  .evidence {
    display: grid;
    gap: var(--s-4);
  }
  .ev-scale {
    display: flex;
    justify-content: space-between;
    font-size: 0.7rem;
    color: var(--muted);
    font-family: var(--font-data);
  }
  .reset {
    justify-self: start;
  }
  .readout {
    text-align: center;
  }
  .big-label {
    margin: 0;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .big-num {
    margin: 0.1em 0 var(--s-4);
    font-size: clamp(2.6rem, 2rem + 3vw, 4rem);
    font-weight: 700;
    line-height: 1;
    color: var(--sky-ink);
  }
  .band {
    position: relative;
    height: 34px;
    background: var(--surface-2);
    border-radius: 999px;
    border: 1px solid var(--line);
  }
  .band-range {
    position: absolute;
    top: 0;
    bottom: 0;
    background: color-mix(in srgb, var(--sun-soft) 80%, white);
    border-left: 2px solid var(--sun);
    border-right: 2px solid var(--sun);
  }
  .band-marker {
    position: absolute;
    top: -5px;
    bottom: -5px;
    width: 3px;
    background: var(--sky-ink);
    border-radius: 2px;
    transition: left 0.25s ease;
  }
  .band-label {
    position: absolute;
    bottom: -1.4em;
    font-size: 0.68rem;
    color: var(--sun-ink);
    transform: translateX(-50%);
  }
  .band-caption {
    margin: 2em 0 0;
    font-size: 0.8rem;
    color: var(--muted);
  }
  .math {
    margin-top: var(--s-5);
    border-top: 1px solid var(--line);
    padding-top: var(--s-3);
  }
  .math summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--sky-ink);
    font-family: var(--font-data);
    font-size: 0.85rem;
  }
  .math p {
    margin-top: var(--s-3);
    color: var(--muted);
    font-size: 0.92rem;
  }
  @media (prefers-reduced-motion: reduce) {
    .band-marker {
      transition: none;
    }
  }
</style>

<script>
  import { initBayes } from '../../scripts/bayes';
  initBayes();
</script>
