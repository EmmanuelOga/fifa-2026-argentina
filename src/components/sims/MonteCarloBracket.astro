---
/**
 * Tab 4 island — Monte Carlo bracket. Reads the current bracket + team strengths
 * from src/data, runs 10,000 seeded tournaments, and shows title odds. A single,
 * clearly-labelled speculative "bias nudge" adds capped percentage points to
 * Argentina's per-match win probability. Clean vs adjusted shown side by side;
 * at nudge = 0 with default strengths the adjusted bars equal the clean ones.
 */
import type { Locale } from '../../lib/i18n';
import { HTML_LANG } from '../../lib/i18n';
import { UI } from '../../i18n/ui';
import { section } from '../../lib/content';
import { TEAMS, SEMIFINALS, FINAL, bracketStage } from '../../data/bracket';
import { OPTA } from '../../data/models';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const s = UI[locale].sim;
const math = await section('whowins-mc-math', locale);
const nudgeNote = await section('whowins-nudge-note', locale);

const codes = ['FRA', 'ESP', 'ENG', 'ARG'];
const config = {
  numLocale: HTML_LANG[locale],
  labels: s,
  stage: bracketStage(),
  seed: 20260712,
  runs: 10000,
  maxNudgePp: 20,
  teams: codes.map((c) => ({
    code: c,
    name: TEAMS[c]!.name[locale],
    flag: TEAMS[c]!.flag,
    rating: TEAMS[c]!.rating,
    opta: OPTA.teams[c as keyof typeof OPTA.teams]?.title ?? null,
  })),
  semifinals: SEMIFINALS.map((m) => ({
    home: m.home,
    away: m.away,
    winner: m.result?.winner ?? null,
  })),
  final: { winner: FINAL.result?.winner ?? null },
};
---

<div class="sim card" data-sim="montecarlo">
  <script type="application/json" is:inline data-config set:html={JSON.stringify(config)} />
  <p class="sim-flag spec">{UI[locale].speculative}</p>

  <div class="mc-grid">
    <div class="controls">
      <p class="ctrl-head">{s.strength}</p>
      <div class="strengths" data-strengths></div>

      <label class="ctrl nudge">
        <span class="ctrl-label warn">
          ⚠ {s.biasNudge}: <b class="data" data-out="nudge">off</b>
        </span>
        <input type="range" min="0" max="20" step="1" value="0" data-in="nudge" />
      </label>

      <div class="mc-actions">
        <label class="seed">
          {s.seed}
          <input type="number" value="20260712" data-in="seed" class="data" />
        </label>
        <button type="button" class="btn primary" data-run>{s.runSim}</button>
      </div>
    </div>

    <div class="results">
      <p class="big-label">{s.titleOdds}</p>
      <div class="bars" data-bars></div>
      <p class="conv" data-out="conv"></p>
    </div>
  </div>

  <details class="math nerd-only">
    <summary>{UI[locale].theMath} — Monte Carlo</summary>
    <p>{math.full}</p>
    <p class="assump">{nudgeNote.full}</p>
  </details>
  <p class="nerd-cta">
    {s.nerdCta}
    <button type="button" class="btn" data-nerd-cta>{s.nerdCtaBtn}</button>
  </p>
</div>

<style>
  .sim {
    padding: var(--s-5);
  }
  .sim-flag {
    margin: 0 0 var(--s-4);
  }
  .mc-grid {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: var(--s-5);
  }
  @media (max-width: 760px) {
    .mc-grid {
      grid-template-columns: 1fr;
    }
  }
  .controls {
    display: grid;
    gap: var(--s-4);
    align-content: start;
  }
  .ctrl-head {
    font-family: var(--font-data);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--muted);
    margin: 0;
  }
  .strengths {
    display: grid;
    gap: var(--s-3);
  }
  .ctrl {
    display: grid;
    gap: var(--s-2);
  }
  .ctrl-label {
    font-size: 0.86rem;
    font-weight: 500;
  }
  .ctrl-label.warn {
    color: var(--pop);
  }
  .str-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.6em;
    align-items: center;
    font-size: 0.86rem;
  }
  input[type='range'] {
    width: 100%;
    accent-color: var(--sky);
  }
  .nudge input[type='range'] {
    accent-color: var(--pop);
  }
  .mc-actions {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: var(--s-3);
    flex-wrap: wrap;
  }
  .seed {
    font-size: 0.78rem;
    color: var(--muted);
    display: grid;
    gap: 0.2em;
  }
  .seed input {
    width: 8rem;
    padding: 0.35em 0.5em;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    background: var(--surface-2);
    color: var(--ink);
  }
  .btn.primary {
    background: var(--sky);
    color: #041220;
    border-color: var(--sky);
    box-shadow: var(--glow-sky);
  }
  .results {
    align-content: start;
  }
  .big-label {
    margin: 0 0 var(--s-3);
    font-size: 0.85rem;
    color: var(--muted);
  }
  .bars {
    display: grid;
    gap: var(--s-3);
  }
  .bar-row {
    display: grid;
    gap: 0.3em;
  }
  .bar-top {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .bar-track {
    position: relative;
    height: 26px;
    background: var(--surface-2);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  .bar-clean,
  .bar-adj {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    border-radius: var(--radius-sm);
    transition: width 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .bar-clean {
    background: color-mix(in srgb, var(--sky) 30%, var(--surface-2));
  }
  .bar-adj {
    background: var(--sky);
    opacity: 0.9;
    height: 10px;
    top: 8px;
  }
  .bar-adj.nudged {
    background: var(--pop);
  }
  .bar-vals {
    display: flex;
    gap: 0.8em;
    font-size: 0.78rem;
    color: var(--muted);
    font-family: var(--font-data);
  }
  .swatch {
    display: inline-block;
    width: 0.7em;
    height: 0.7em;
    border-radius: 2px;
    vertical-align: middle;
    margin-right: 0.3em;
  }
  .conv {
    margin: var(--s-4) 0 0;
    font-size: 0.82rem;
    color: var(--muted);
  }
  .math {
    margin-top: var(--s-5);
    border-top: 1px solid var(--line);
    padding-top: var(--s-3);
  }
  .math summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--sky-ink);
    font-family: var(--font-data);
    font-size: 0.85rem;
  }
  .math p {
    margin-top: var(--s-3);
    color: var(--muted);
    font-size: 0.92rem;
  }
  @media (prefers-reduced-motion: reduce) {
    .bar-clean,
    .bar-adj {
      transition: none;
    }
  }
</style>

<script>
  import { initMonteCarlo } from '../../scripts/montecarlo';
  initMonteCarlo();
</script>
