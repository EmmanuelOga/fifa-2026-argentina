---
/**
 * Home / hero page body. Sets the joy → honest look → joy arc, the bias
 * disclosure and caveats boxes, and links into the five tabs. All prose from the
 * content layer.
 */
import type { Locale } from '../../lib/i18n';
import { TAB_KEYS } from '../../lib/i18n';
import { UI, TAB_LABEL } from '../../i18n/ui';
import { tabPath } from '../../lib/url';
import { section, updates } from '../../lib/content';
import Hero from '../Hero.astro';
import Callout from '../Callout.astro';
import Prose from '../Prose.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = UI[locale];
const bias = await section('bias-disclosure', locale);
const caveats = await section('caveats', locale);
// Latest Log entry feeds the one-line news banner (updates() sorts newest first).
const latestRun = (await updates())[0];
const twoThreads = await section('story-two-threads', locale);
const closing = await section('closing-note', locale);

const tabBlurb: Record<string, { en: string; es: string }> = {
  story: { en: 'What actually happened, as a timeline.', es: 'Lo que realmente pasó, en una línea de tiempo.' },
  feasibility: { en: 'Could a fix even be pulled off? A simulator.', es: '¿Se puede siquiera arreglar? Un simulador.' },
  probabilities: { en: 'Four hypotheses, and a Bayesian playground.', es: 'Cuatro hipótesis y un patio bayesiano.' },
  'who-wins': { en: 'The models, the market, and a Monte Carlo.', es: 'Los modelos, el mercado y un Monte Carlo.' },
  ask: { en: 'Chat with the compiled research.', es: 'Chateá con la investigación compilada.' },
  sources: { en: 'Everything, traced to a source.', es: 'Todo, rastreado a una fuente.' },
  log: { en: 'A living changelog of re-runs.', es: 'Un changelog vivo de re-corridas.' },
};
---

<Hero locale={locale} />

<div class="container-narrow home-body stack">
  {latestRun && (
    <a class="news-banner" href={tabPath(locale, 'log')}>
      <span class="nb-tag">{locale === 'es' ? '¡Mirá la Bitácora!' : 'Check the Log!'}</span>
      <span class="nb-text">
        {locale === 'es' ? 'Lo último' : 'Latest'}: {latestRun.data.content[locale].title}
      </span>
      <span class="nb-arrow" aria-hidden="true">→</span>
    </a>
  )}

  {/* Two audiences, two doors: casual readers vs the stats-hungry. */}
  <div class="paths">
    <a class="path-card" href={tabPath(locale, 'story')}>
      <span class="pc-icon" aria-hidden="true">🧉</span>
      <span class="pc-title">{locale === 'es' ? 'Quiero la historia' : 'Just want the story'}</span>
      <span class="pc-blurb">
        {locale === 'es'
          ? 'Qué pasó, qué se dice y qué es cierto. Sin matemática.'
          : 'What happened, what people claim, and what holds up. No math.'}
      </span>
    </a>
    <a class="path-card" href={tabPath(locale, 'who-wins')}>
      <span class="pc-icon" aria-hidden="true">📊</span>
      <span class="pc-title">{locale === 'es' ? 'Vengo por los números' : "Here for the stats"}</span>
      <span class="pc-blurb">
        {locale === 'es'
          ? 'Modelos, probabilidades, simulaciones Monte Carlo y Bayes.'
          : 'Models, probabilities, Monte Carlo sims and Bayes.'}
      </span>
    </a>
  </div>

  <Callout variant="sky" icon="🙋" title={bias.headline}>
    <p>{bias.full}</p>
  </Callout>

  <Callout variant="sun" icon="🧵" title={twoThreads.headline}>
    <p>{twoThreads.full}</p>
  </Callout>

  <section aria-label="Sections">
    <h2>{locale === 'es' ? 'Recorré el análisis' : 'Explore the analysis'}</h2>
    <div class="tab-cards">
      {
        TAB_KEYS.map((key) => (
          <a class="tab-card" href={tabPath(locale, key)}>
            <span class="tc-name">{TAB_LABEL[key][locale]}</span>
            <span class="tc-blurb">{tabBlurb[key]![locale]}</span>
            <span class="tc-arrow" aria-hidden="true">→</span>
          </a>
        ))
      }
    </div>
  </section>

  <Callout variant="pop" icon="⚠️" title={caveats.headline}>
    <Prose data={caveats} list="ul" />
  </Callout>

  <Callout variant="plain" icon="🇦🇷" title={closing.headline}>
    <p class="closing">{closing.full}</p>
  </Callout>
</div>

<style>
  .news-banner {
    display: flex;
    align-items: baseline;
    gap: var(--s-3);
    flex-wrap: wrap;
    padding: var(--s-3) var(--s-4);
    border: 1px solid var(--sky);
    border-radius: var(--radius);
    background: var(--sky-soft);
    text-decoration: none;
    color: var(--ink);
  }
  .news-banner:hover {
    background: color-mix(in srgb, var(--sky-soft) 70%, white);
  }
  .nb-tag {
    font-family: var(--font-data);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sky-ink);
    white-space: nowrap;
  }
  .nb-text {
    font-size: 0.9rem;
    flex: 1;
    min-width: 12em;
  }
  .nb-arrow {
    color: var(--sky-ink);
  }
  .paths {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-4);
  }
  .path-card {
    display: grid;
    gap: 0.35em;
    padding: var(--s-4) var(--s-5);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: var(--ink);
  }
  .path-card:hover {
    border-color: var(--sky);
    background: var(--sky-soft);
  }
  .pc-icon {
    font-size: 1.4rem;
  }
  .pc-title {
    font-weight: 700;
  }
  .pc-blurb {
    font-size: 0.85rem;
    color: var(--muted);
  }
  @media (max-width: 560px) {
    .paths {
      grid-template-columns: 1fr;
    }
  }
  .home-body {
    padding-block: var(--s-6) var(--s-7);
  }
  .tab-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: var(--s-3);
  }
  .tab-card {
    position: relative;
    display: grid;
    gap: 0.25em;
    text-decoration: none;
    color: inherit;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: var(--s-4);
    box-shadow: var(--shadow-sm);
    transition: transform 0.12s ease, border-color 0.12s ease, box-shadow 0.12s ease;
  }
  .tab-card:hover {
    transform: translateY(-2px);
    border-color: var(--sky);
    box-shadow: var(--shadow);
  }
  .tc-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--sky-ink);
  }
  .tc-blurb {
    font-size: 0.9rem;
    color: var(--muted);
  }
  .tc-arrow {
    position: absolute;
    top: var(--s-4);
    right: var(--s-4);
    color: var(--sun);
    font-weight: 700;
  }
  .closing {
    font-size: var(--step-1);
    margin: 0;
  }
</style>
