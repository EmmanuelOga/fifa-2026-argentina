---
/**
 * "Ask the research" chat island. Posts to the /api/ask Pages Function, which
 * answers only from the compiled research. Degrades gracefully when the endpoint
 * is absent (e.g. the GitHub Pages fallback has no serverless functions).
 */
import type { Locale } from '../lib/i18n';
import { UI } from '../i18n/ui';
import { withBase } from '../lib/url';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const a = UI[locale].ask;
const config = { endpoint: withBase('/api/ask'), locale, labels: a };
const LINKEDIN = 'https://www.linkedin.com/in/emmanueloga/';
---

<div class="ask card" data-ask>
  <script type="application/json" is:inline data-config set:html={JSON.stringify(config)} />

  <div class="ask-log" data-log aria-live="polite"></div>

  <div class="suggest" data-suggest>
    <span class="suggest-label">{a.suggestions}:</span>
    {a.suggestionList.map((q) => (
      <button type="button" class="chip" data-q={q}>{q}</button>
    ))}
  </div>

  <form class="ask-form" data-form>
    <input
      type="text"
      name="q"
      data-input
      maxlength="1000"
      placeholder={a.placeholder}
      autocomplete="off"
      aria-label={a.placeholder}
    />
    <button type="submit" class="btn primary" data-send>{a.send}</button>
  </form>

  <p class="ask-disclaimer">
    {a.disclaimer} <a href={LINKEDIN}>LinkedIn</a>.
  </p>
</div>

<style>
  .ask {
    padding: var(--s-5);
  }
  .ask-log {
    display: grid;
    gap: var(--s-3);
    margin-bottom: var(--s-4);
  }
  .ask-log:empty {
    display: none;
  }
  .msg {
    padding: var(--s-3) var(--s-4);
    border-radius: var(--radius);
    max-width: 90%;
  }
  .msg.you {
    justify-self: end;
    background: var(--sky);
    color: white;
    border-bottom-right-radius: 4px;
  }
  .msg.bot {
    justify-self: start;
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-bottom-left-radius: 4px;
  }
  .msg .who {
    display: block;
    font-family: var(--font-data);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.7;
    margin-bottom: 0.2em;
  }
  .msg .srcs {
    margin-top: var(--s-2);
    font-size: 0.78rem;
    color: var(--muted);
  }
  .msg.bot.thinking {
    color: var(--muted);
    font-style: italic;
  }
  .suggest {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    align-items: center;
    margin-bottom: var(--s-4);
  }
  .suggest-label {
    font-size: 0.8rem;
    color: var(--muted);
    width: 100%;
  }
  .chip {
    font: inherit;
    font-size: 0.82rem;
    cursor: pointer;
    border: 1px solid var(--line);
    background: var(--surface);
    color: var(--sky-ink);
    border-radius: 999px;
    padding: 0.4em 0.8em;
  }
  .chip:hover {
    border-color: var(--sky);
    background: var(--sky-soft);
  }
  .ask-form {
    display: flex;
    gap: var(--s-2);
  }
  .ask-form input {
    flex: 1;
    font: inherit;
    padding: 0.7em 0.9em;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface);
  }
  .ask-form input:focus-visible {
    border-color: var(--sky);
  }
  .btn.primary {
    background: var(--sky);
    color: white;
    border-color: var(--sky);
  }
  .btn.primary[disabled] {
    opacity: 0.6;
    cursor: default;
  }
  .ask-disclaimer {
    margin: var(--s-4) 0 0;
    font-size: 0.78rem;
    color: var(--muted);
  }
</style>

<script>
  import { initAsk } from '../scripts/ask';
  initAsk();
</script>
