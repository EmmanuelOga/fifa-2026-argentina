---
/**
 * "Ask the research" chat island. Posts to the /api/ask Pages Function, which
 * answers only from the compiled research. While a question is in flight the
 * whole composer locks and a typing indicator holds the reply's place; answers
 * render as sanitized Markdown (scripts/markdown.ts). Degrades gracefully when
 * the endpoint is absent (e.g. a static-only fallback deploy).
 */
import type { Locale } from '../lib/i18n';
import { UI } from '../i18n/ui';
import { withBase } from '../lib/url';
import { meta } from '../data/meta';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const a = UI[locale].ask;
const config = {
  endpoint: withBase('/api/ask'),
  locale,
  turnstileSiteKey: meta.turnstileSiteKey,
  labels: a,
};
const LINKEDIN = 'https://www.linkedin.com/in/emmanueloga/';
---

<div class="ask card" data-ask>
  <script type="application/json" is:inline data-config set:html={JSON.stringify(config)} />

  <div class="ask-log" data-log aria-live="polite"></div>

  <div class="suggest" data-suggest>
    <span class="suggest-label">{a.suggestions}:</span>
    {a.suggestionList.map((q) => (
      <button type="button" class="chip" data-q={q}>{q}</button>
    ))}
  </div>

  {/* Turnstile mounts here when a site key is configured (interaction-only:
      invisible unless Cloudflare decides the visitor needs a challenge). */}
  <div class="turnstile" data-turnstile></div>

  <form class="ask-form" data-form>
    <input
      type="text"
      name="q"
      data-input
      maxlength="1000"
      placeholder={a.placeholder}
      autocomplete="off"
      aria-label={a.placeholder}
    />
    <button type="submit" class="btn primary" data-send>{a.send}</button>
  </form>

  <p class="ask-disclaimer">
    {a.disclaimer} <a href={LINKEDIN}>LinkedIn</a>.
  </p>
</div>

<style>
  .ask {
    padding: var(--s-5);
  }
  .ask-log {
    display: grid;
    gap: var(--s-3);
    margin-bottom: var(--s-4);
  }
  .ask-log:empty {
    display: none;
  }
  /* Chat messages are injected at runtime by scripts/ask.ts, so Astro's scoped
     selectors can't reach them — everything below is rooted at the static .ask
     container via :global(). */
  .ask :global(.msg) {
    padding: var(--s-3) var(--s-4);
    border-radius: var(--radius);
    max-width: 92%;
    font-size: 0.95rem;
  }
  .ask :global(.msg.you) {
    justify-self: end;
    background: linear-gradient(180deg, rgba(62, 193, 255, 0.16), rgba(62, 193, 255, 0.08)) var(--surface-2);
    border: 1px solid color-mix(in srgb, var(--sky) 40%, transparent);
    border-right: 3px solid var(--sky);
  }
  .ask :global(.msg.bot) {
    justify-self: start;
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-left: 3px solid var(--sun);
  }
  .ask :global(.msg .who) {
    display: block;
    font-family: var(--font-data);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin-bottom: 0.3em;
  }
  .ask :global(.msg.you .who) {
    color: var(--sky);
  }
  .ask :global(.msg.bot .who) {
    color: var(--sun-ink);
  }

  /* markdown body (rendered by scripts/markdown.ts) */
  .ask :global(.msg-body > *:first-child) {
    margin-top: 0;
  }
  .ask :global(.msg-body > *:last-child) {
    margin-bottom: 0;
  }
  .ask :global(.msg-body p) {
    margin: 0 0 0.6em;
  }
  .ask :global(.msg-body ul),
  .ask :global(.msg-body ol) {
    margin: 0 0 0.6em;
    padding-left: 1.25em;
    display: grid;
    gap: 0.25em;
  }
  .ask :global(.msg-body code) {
    font-family: var(--font-data);
    font-size: 0.86em;
    background: rgba(62, 193, 255, 0.12);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    padding: 0.05em 0.35em;
  }
  .ask :global(.msg-body pre) {
    overflow-x: auto;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    padding: var(--s-3);
    margin: 0 0 0.6em;
  }
  .ask :global(.msg-body pre code) {
    background: none;
    border: 0;
    padding: 0;
  }

  /* typing indicator */
  .ask :global(.msg.thinking) {
    color: var(--muted);
  }
  .ask :global(.dots) {
    display: inline-flex;
    gap: 0.25em;
    margin-right: 0.35em;
    vertical-align: baseline;
  }
  .ask :global(.dots i) {
    width: 0.4em;
    height: 0.4em;
    border-radius: 50%;
    background: var(--sky);
    animation: ask-dot 1.1s infinite ease-in-out;
  }
  .ask :global(.dots i:nth-child(2)) {
    animation-delay: 0.18s;
  }
  .ask :global(.dots i:nth-child(3)) {
    animation-delay: 0.36s;
  }
  @keyframes ask-dot {
    0%,
    70%,
    100% {
      opacity: 0.25;
      transform: translateY(0);
    }
    35% {
      opacity: 1;
      transform: translateY(-0.16em);
    }
  }

  /* source chips */
  .ask :global(.srcs) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35em;
    align-items: center;
    margin-top: var(--s-3);
    padding-top: var(--s-2);
    border-top: 1px dashed var(--line);
  }
  .ask :global(.srcs-label) {
    font-family: var(--font-data);
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin-right: 0.2em;
  }
  .ask :global(.src-chip) {
    font-family: var(--font-data);
    font-size: 0.72rem;
    color: var(--sky-ink);
    background: var(--sky-soft);
    border: 1px solid color-mix(in srgb, var(--sky) 35%, transparent);
    border-radius: var(--radius-sm);
    padding: 0.12em 0.5em;
  }

  .suggest {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    align-items: center;
    margin-bottom: var(--s-4);
  }
  .suggest-label {
    font-size: 0.8rem;
    color: var(--muted);
    width: 100%;
  }
  .chip {
    font: inherit;
    font-size: 0.82rem;
    cursor: pointer;
    border: 1px solid var(--line);
    background: var(--surface-2);
    color: var(--sky-ink);
    border-radius: var(--radius-sm);
    padding: 0.4em 0.8em;
    transition: border-color 0.12s ease, background 0.12s ease, box-shadow 0.12s ease;
  }
  .chip:hover:not(:disabled) {
    border-color: var(--sky);
    background: var(--sky-soft);
    box-shadow: var(--glow-sky);
  }
  .chip:disabled {
    opacity: 0.45;
    cursor: default;
  }
  .ask-form {
    display: flex;
    gap: var(--s-2);
  }
  .ask-form input {
    flex: 1;
    font: inherit;
    padding: 0.7em 0.9em;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--surface-2);
    color: var(--ink);
    transition: border-color 0.12s ease, box-shadow 0.12s ease;
  }
  .ask-form input::placeholder {
    color: var(--muted);
  }
  .ask-form input:focus-visible {
    border-color: var(--sky);
    box-shadow: var(--glow-sky);
    outline: none;
  }
  .ask-form input:disabled {
    opacity: 0.55;
  }
  .btn.primary {
    background: var(--sky);
    color: #041220;
    border-color: var(--sky);
  }
  .btn.primary:hover:not(:disabled) {
    box-shadow: var(--glow-sky);
  }
  .btn.primary:disabled {
    opacity: 0.55;
    cursor: default;
    box-shadow: none;
  }
  .ask-disclaimer {
    margin: var(--s-4) 0 0;
    font-size: 0.78rem;
    color: var(--muted);
  }
</style>

<script>
  import { initAsk } from '../scripts/ask';
  initAsk();
</script>
