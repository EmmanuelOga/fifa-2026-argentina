---
/**
 * Sticky header: brand + byline, the tab nav (routes), a language toggle that
 * swaps to the equivalent page in the other locale, and the nerd-mode switch
 * (see scripts/nerd.ts — reveals .nerd-only extras and opens sim math). On
 * mobile the tab nav becomes a horizontally-scrollable bar usable at 360px.
 */
import { TAB_KEYS, otherLocale, type Locale, type TabKey } from '../lib/i18n';
import { tabPath, homePath } from '../lib/url';
import { UI, TAB_LABEL, TAB_SHORT } from '../i18n/ui';

interface Props {
  locale: Locale;
  current?: TabKey;
}
const { locale, current } = Astro.props;
const t = UI[locale];
const other = otherLocale(locale);
// Language toggle target: same tab in the other locale, or the other home page.
const toggleHref = current ? tabPath(other, current) : homePath(other);
---

<header class="site-header">
  <div class="container bar">
    <a class="brand" href={homePath(locale)}>
      <span class="brand-mark" aria-hidden="true">
        <span class="stripe"></span><span class="stripe sun"></span><span class="stripe"></span>
      </span>
      <span class="brand-text">
        <span class="brand-name">La Alegría</span>
        <span class="brand-tag">{t.tagline}</span>
      </span>
    </a>

    <div class="switches">
      <button
        type="button"
        class="nerd-toggle"
        data-nerd-toggle
        aria-pressed="false"
        title={t.nerdHint}
      >
        <span aria-hidden="true">🤓</span> {t.nerdMode}
      </button>
      <a class="lang-toggle" href={toggleHref} hreflang={other === 'es' ? 'es-AR' : 'en'} rel="alternate">
        <span aria-hidden="true">🌐</span> {t.switchTo}
      </a>
    </div>
  </div>

  <nav class="tabs container" aria-label={t.primaryNav}>
    <ul>
      {
        TAB_KEYS.map((key) => (
          <li>
            <a
              href={tabPath(locale, key)}
              class:list={['tab', { active: current === key }]}
              aria-current={current === key ? 'page' : undefined}
            >
              <span class="full">{TAB_LABEL[key][locale]}</span>
              <span class="short">{TAB_SHORT[key][locale]}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(5, 14, 28, 0.82);
    backdrop-filter: saturate(1.3) blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    padding-block: var(--s-3);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--s-3);
    text-decoration: none;
    color: inherit;
  }
  .brand-mark {
    display: inline-grid;
    grid-auto-flow: row;
    gap: 2px;
    width: 26px;
  }
  .brand-mark .stripe {
    height: 5px;
    background: var(--sky);
    box-shadow: var(--glow-sky);
  }
  .brand-mark .stripe.sun {
    background: var(--sun);
    box-shadow: var(--glow-sun);
  }
  .brand-name {
    display: block;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.28rem;
    line-height: 1;
    color: var(--sky-ink);
    letter-spacing: -0.02em;
  }
  .brand-tag {
    display: block;
    font-size: 0.74rem;
    color: var(--muted);
  }
  @media (max-width: 560px) {
    .brand-tag {
      display: none;
    }
  }
  .switches {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    flex: none;
  }
  .lang-toggle,
  .nerd-toggle {
    font-family: var(--font-data);
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    color: var(--sky-ink);
    border: 1px solid var(--line);
    background: transparent;
    padding: 0.45em 0.8em;
    border-radius: var(--radius-sm);
    transition: border-color 0.12s ease, background 0.12s ease, box-shadow 0.12s ease;
  }
  .lang-toggle:hover,
  .nerd-toggle:hover {
    border-color: var(--sky);
    background: var(--sky-soft);
    box-shadow: var(--glow-sky);
  }
  .nerd-toggle[aria-pressed='true'] {
    border-color: var(--sun);
    background: var(--sun-soft);
    color: var(--sun-ink);
    box-shadow: var(--glow-sun);
  }
  @media (max-width: 420px) {
    .nerd-toggle {
      font-size: 0.7rem;
      padding: 0.45em 0.55em;
    }
  }
  .tabs {
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .tabs::-webkit-scrollbar {
    display: none;
  }
  .tabs ul {
    display: flex;
    gap: var(--s-1);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .tab {
    display: inline-block;
    white-space: nowrap;
    text-decoration: none;
    font-family: var(--font-data);
    font-weight: 600;
    font-size: 0.84rem;
    letter-spacing: 0.03em;
    color: var(--muted);
    padding: 0.55em 0.9em 0.7em;
    border-bottom: 2px solid transparent;
    transition: color 0.12s ease, background 0.12s ease, border-color 0.12s ease;
  }
  .tab:hover {
    color: var(--sky-ink);
    background: var(--sky-soft);
  }
  .tab.active {
    color: var(--sky);
    border-bottom-color: var(--sky);
    text-shadow: 0 0 14px rgba(62, 193, 255, 0.55);
  }
  .tab .short {
    display: none;
  }
  @media (max-width: 640px) {
    .tab .full {
      display: none;
    }
    .tab .short {
      display: inline;
    }
  }
</style>

<script>
  import { initNerdMode } from '../scripts/nerd';
  initNerdMode();
</script>
