---
/**
 * Renders inline source citations for a content item. Verified sources link out;
 * unverified ones (no canonical URL) link to a web search and are labelled, per
 * the defamation-hygiene rule that every claim traces to a source.
 */
import type { Locale } from '../lib/i18n';
import { UI } from '../i18n/ui';
import { sourceCite } from '../lib/content';

interface Props {
  ids: string[];
  locale: Locale;
}
const { ids, locale } = Astro.props;
const t = UI[locale];
const cites = (await Promise.all(ids.map((id) => sourceCite(id, locale)))).filter(
  (c): c is NonNullable<typeof c> => Boolean(c),
);
const searchUrl = (q: string) => `https://www.google.com/search?q=${encodeURIComponent(q)}`;
---

{
  cites.length > 0 && (
    <p class="srcs">
      <span class="srcs-label">{t.sourcesForThis}:</span>
      {cites.map((c, i) => (
        <>
          {c.url && !c.unverified ? (
            <a href={c.url} target="_blank" rel="noopener">
              {c.title} ↗
            </a>
          ) : (
            <a href={searchUrl(c.title)} target="_blank" rel="noopener" class="unverified">
              {c.title} <span class="uv">({t.linkUnverified})</span>
            </a>
          )}
          {i < cites.length - 1 && <span class="sep"> · </span>}
        </>
      ))}
    </p>
  )
}

<style>
  .srcs {
    margin: var(--s-3) 0 0;
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.7;
  }
  .srcs-label {
    font-family: var(--font-data);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.68rem;
    font-weight: 600;
    margin-right: 0.3em;
  }
  .srcs a {
    font-weight: 500;
  }
  .unverified {
    color: var(--muted);
  }
  .uv {
    font-style: italic;
  }
</style>
