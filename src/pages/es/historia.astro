---
import Base from '../../layouts/Base.astro';
import StoryPage from '../../components/pages/StoryPage.astro';
import { section } from '../../lib/content';
const locale = 'es' as const;
const meta = await section('story-intro', locale);
---

<Base locale={locale} tab="story" title={meta.headline} description={meta.short}>
  <StoryPage locale={locale} />
</Base>
